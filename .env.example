# ---------------------------------------------------------------------------
# Aplicação — defina APP_KEY com: php artisan key:generate
# APP_URL deve bater com o host real (impacta URLs assinadas, cookies e DNS admin).
# ---------------------------------------------------------------------------
APP_NAME=BateriaExpert
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Integrações opcionais (dev/automação) — sem estes valores, rotas que chamam
# N8N/Evolution podem falhar; segredos obrigatórios em produção.
# ---------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
EVOLUTION_API_KEY=change-me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Banco central (ERP / plataforma) — em CI local costuma ser SQLite; em Docker/prod, PostgreSQL.
# ---------------------------------------------------------------------------
DB_CONNECTION=central

DB_CENTRAL_DRIVER=pgsql
DB_CENTRAL_HOST=erp_core_db
DB_CENTRAL_PORT=5432
DB_CENTRAL_DATABASE=erp_central
DB_CENTRAL_USERNAME=erp
DB_CENTRAL_PASSWORD=erp

# ---------------------------------------------------------------------------
# Tenant (filial) — DB_TENANT_HOST costuma ficar vazio até o TenantConnectionMiddleware
# preencher a partir do Cliente em produção; em CI/Docker declare host explícito.
# DB_TENANT_PASSWORD: use em dev local fixo ou deixe vazio se só pooler/session.
# Em Supabase típico: pool na porta 6543.
# ---------------------------------------------------------------------------
DB_TENANT_DRIVER=pgsql
# DB_TENANT_HOST=
DB_TENANT_PORT=6543
DB_TENANT_DATABASE=postgres
DB_TENANT_USERNAME=postgres
# DB_TENANT_PASSWORD=

# ---------------------------------------------------------------------------
# Supabase (CLI / provisionamento) — deixe vazio se não usar automação de projetos.
# ---------------------------------------------------------------------------
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
SUPABASE_REGION=sa-east-1
SUPABASE_PROJECT_PLAN=free

# ---------------------------------------------------------------------------
# Serviços internos — HMAC/header entre APIs; gere um valor longo aleatório em produção.
# ---------------------------------------------------------------------------
INTERNAL_SERVICE_KEY=your-secure-internal-key-here

# ---------------------------------------------------------------------------
# Sessões / fila / cache — em dev com Sail use redis conforme compose; PHPUnit costuma usar array/sync.
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=erp_core_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Microserviços (rede Docker / k8s) — ajuste host para o seu ambiente.
# ---------------------------------------------------------------------------
MS_FISCAL_URL=http://ms_001_fiscal_api:8001
MS_BANCARIO_URL=http://ms_002_banking_api:8002
MS_WHATSAPP_URL=http://ms_003_notification_api:8003
MS_OPENFINANCE_URL=http://ms_004_openfinance_api:8004
MS_GEOCODING_URL=http://ms_005_geocoding_api:8005
INVENTORY_SHELF_LIFE_DAYS=90

RUN_MIGRATIONS=false
MAINTENANCE_MODE=false
# MAINTENANCE_ALLOWED_IPS=127.0.0.1,10.0.0.0/8
# CORS_ALLOWED_ORIGINS=https://erp.example.com,https://admin.erp.example.com

# ---------------------------------------------------------------------------
# Seed / bootstrap administrativo — NUNCA deixe a senha padrão em produção.
# ---------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@bateriaexpert.com
SUPER_ADMIN_PASSWORD=change-me-before-deploy

# ---------------------------------------------------------------------------
# Jetstream — flags de recurso da stack de autenticação / perfil.
# ---------------------------------------------------------------------------
TWO_FACTOR_AUTH=true
API_TOKENS=true
PROFILE_PHOTOS=true
EMAIL_VERIFICATION=true
TEAMS=true
ACCOUNT_DELETION=true
TERMS_AND_PRIVACY_POLICY=true

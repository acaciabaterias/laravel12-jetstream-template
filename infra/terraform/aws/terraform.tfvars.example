project_name = "bateriaexpert"
environment  = "production"
aws_region   = "us-east-1"
key_pair_name = "bateriaexpert-prod"

availability_zones = [
  "us-east-1a",
  "us-east-1b"
]

public_subnet_cidrs = [
  "10.30.1.0/24",
  "10.30.2.0/24"
]

private_subnet_cidrs = [
  "10.30.11.0/24",
  "10.30.12.0/24"
]

allowed_ssh_cidrs = [
  "203.0.113.10/32"
]

allowed_http_cidrs = [
  "0.0.0.0/0"
]

rds_instance_class    = "db.t4g.medium"
rds_allocated_storage = 100
rds_db_name           = "erp_central"
rds_username          = "erp"
rds_password          = "change-me-strong-password"

redis_node_type      = "cache.t4g.small"
redis_engine_version = "7.1"

ec2_instances = {
  erp_core = {
    ami_id               = "ami-0123456789abcdef0"
    instance_type        = "t3.large"
    subnet_type          = "public"
    associate_public_ip  = true
    root_volume_size_gib = 80
  }
  microservices = {
    ami_id               = "ami-0123456789abcdef0"
    instance_type        = "t3.large"
    subnet_type          = "private"
    associate_public_ip  = false
    root_volume_size_gib = 80
  }
}
